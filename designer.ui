  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #1e1e24; /* Deep Charcoal */
}

/* Style the Labels (X, Y, Z, YAW) */
QLabel {
    color: #00d4ff; /* Cyan */
    font-weight: bold;
    font-family: &quot;Consolas&quot;, monospace; /* Makes it look like code/data */
}

/* Style the Input Boxes */
QLineEdit {
    background-color: #121214;
    color: #ffffff;
    border: 1px solid #33333a;
    border-radius: 3px;
    padding: 2px;
}

/* Style the Launch &amp; Send Buttons */
QPushButton {
    background-color: #2b2b33;
    color: #00d4ff;
    border: 2px solid #00d4ff;
    border-radius: 5px;
    font-weight: bold;
    padding: 5px;
}

QPushButton:hover {
    background-color: #00d4ff;
    color: #1e1e24;
}
#graph_3d, #graph_closeup {
    border: 1px solid #444444; /* Use #ffffff for white, or #444444 for a subtle gray */
    background-color: #000000;
}</string>
